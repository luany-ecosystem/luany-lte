{
    "name": "luany/lte",
    "description": "LTE — AST-based template engine for PHP. Compiler-grade templating with zero regex parsing.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "António Ambrósio Ngola",
            "email": "antoniongola.dev@gmail.com",
            "homepage": "https://github.com/luany-ecosystem",
            "role": "Lead Engineer"
        }
    ],
    "keywords": [
        "php",
        "template",
        "engine",
        "ast",
        "compiler",
        "lte",
        "luany"
    ],
    "homepage": "https://github.com/luany-ecosystem/luany-lte",
    "require": {
        "php": ">=8.2"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^2.1"
    },
    "autoload": {
        "psr-4": {
            "Luany\\Lte\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Luany\\Lte\\Tests\\": "tests/"
        }
    },
    "config": {
        "optimize-autoloader": true
    },
    "minimum-stability": "stable"
}
